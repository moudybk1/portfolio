# Password for the /admin panel (default is "admin" if unset — change this!)
ADMIN_PASSWORD=change-me

# Secret used to sign the admin session cookie. Use a long random string.
AUTH_SECRET=generate-a-long-random-string

# Public site URL used for SEO (sitemap, Open Graph, canonical links)
NEXT_PUBLIC_SITE_URL=https://moudy.xyz

# Turso database (required in production, e.g. Vercel).
# When unset, the app falls back to a local SQLite file in data/ — fine for dev.
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token
